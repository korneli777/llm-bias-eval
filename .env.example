# Copy to .env and fill in your real tokens. The .env file is git-ignored.

# HuggingFace token with access to gated repos (Llama, Gemma).
# Get one at: https://huggingface.co/settings/tokens
# Accept licenses on the model pages before running.
HF_TOKEN=hf_your_token_here

# Weights & Biases API key (free academic tier).
# Get one at: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_key_here

# Optional: WandB project + entity. Defaults are fine for solo work.
WANDB_PROJECT=llm-bias-eval
# WANDB_ENTITY=your_team

# Optional: cache dirs. Defaults to ~/.cache/huggingface.
# HF_HOME=/path/to/large/disk
# TRANSFORMERS_CACHE=/path/to/large/disk/transformers
